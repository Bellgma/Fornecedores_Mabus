generator client {
  provider = "prisma-client-js"
}

datasource db {
 provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Supplier {
  id             String    @id @default(cuid())
  razaoSocial    String
  nomeFantasia   String
  cnpj           String
  status         String    @default("Ativo") // Ativo, Inativo, Em Avaliação
  categorias     String    // Separated by comma
  historico      String?   // Nível de Preço / Observações
  localidade     String?
  catalogoResumo String?
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  contatos       Contact[]
}

model Contact {
  id           String   @id @default(cuid())
  nome         String
  cargo        String?
  email        String
  telefone     String?
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model Template {
  id               String   @id @default(cuid())
  nome             String
  assunto          String
  scriptApresentacao String
  corpoEmail       String
  remetente        String   @default("cotacao@mabus.com.br")
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}
