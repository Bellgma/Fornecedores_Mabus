generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Supplier {
  id             String    @id @default(cuid())
  razaoSocial    String
  nomeFantasia   String
  cnpj           String    @unique
  status         String    @default("Em análise") // Ativo, Inativo, Em análise
  categorias     String    // Separated by comma
  historico      String?

  // Endereço e Geolocalização
  cep            String?
  logradouro     String?
  numero         String?
  bairro         String?
  cidade         String?
  estado         String?   // UF (ex: SP, MG)
  latitude       Float?
  longitude      Float?

  catalogoResumo String?
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  contatos       Contact[]
  produtos       Product[]
}

model Contact {
  id           String   @id @default(cuid())
  nome         String
  cargo        String?
  email        String
  telefone     String?
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model Product {
  id           String   @id @default(cuid())
  nome         String
  descricao    String?
  preco        Float?
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model Carrier {
  id           String   @id @default(cuid())
  nome         String
  cnpj         String   @unique
  status       String   @default("Ativo")
  latitude     Float?
  longitude    Float?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model Quote {
  id           String   @id @default(cuid())
  status       String   @default("Aberta") // Aberta, Aguardando, Fechada
  descricao    String
  dataLimite   DateTime?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model Template {
  id               String   @id @default(cuid())
  nome             String
  assunto          String
  scriptApresentacao String
  corpoEmail       String
  remetente        String   @default("cotacao@mabus.com.br")
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model RegistrationToken {
  id           String   @id @default(cuid())
  token        String   @unique
  expiresAt    DateTime
  used         Boolean  @default(false)
  createdAt    DateTime @default(now())
}
